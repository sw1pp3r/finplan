# ── finplan configuration ──────────────────────────────────────────────
# Optional. docker-compose already ships sane defaults, so the app runs with
# no .env at all. Copy this to .env only to override — at minimum, change the
# database credentials below for anything beyond a private/local deployment.

# PostgreSQL credentials. docker-compose uses these for the bundled "db"
# service AND to build the app's DATABASE_URL, so changing them here is enough.
POSTGRES_USER=finplan
POSTGRES_PASSWORD=finplan
POSTGRES_DB=finplan

# Advanced: point the app at an EXTERNAL database instead of the bundled one,
# or use a minimal single-file SQLite setup. If set, this overrides the
# POSTGRES_* values above. Leave it unset to use the bundled PostgreSQL.
#   DATABASE_URL=postgresql+psycopg2://USER:SECRET@your-host:5432/finplan
#   DATABASE_URL=sqlite:////data/finplan.db   (also mount a volume at /data)
# DATABASE_URL=

# Daily FX-rate fetch from open.er-api.com (no API key needed).
# OFF by default — finplan makes NO outbound requests unless you opt in.
# 1 = fetch rates once a day, 0 = never touch the network.
FINPLAN_FX_AUTOFETCH=0

# Optional bearer token guarding /api/*. Empty = no auth, which is fine on
# localhost or a private network. Set a value to require:
#   Authorization: Bearer <token>
FINPLAN_API_TOKEN=

# Where wish-board images are stored (served at /wish-images/...).
FINPLAN_IMAGE_DIR=/srv/finplan/wish-images
