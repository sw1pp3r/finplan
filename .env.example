# ── finplan configuration ──────────────────────────────────────────────
# Optional. The app boots with sensible defaults and NO .env at all
# (SQLite, FX fetch off, no auth, no outbound network). Copy to .env only
# to override. In docker-compose these are set for you — see the compose file.

# Database connection string.
# Default (self-hosting one user): a SQLite file. In docker-compose this
# points at a named volume so your data survives redeploys.
# For PostgreSQL instead, use:
#   DATABASE_URL=postgresql+psycopg2://USER:SECRET@HOST:5432/finplan
DATABASE_URL=sqlite:////data/finplan.db

# Daily FX-rate fetch from open.er-api.com (no API key needed).
# OFF by default — finplan makes NO outbound requests unless you opt in.
# 1 = fetch rates once a day, 0 = never touch the network.
FINPLAN_FX_AUTOFETCH=0

# Optional bearer token guarding /api/*. Empty = no auth, which is fine on
# localhost or a private network. Set a value to require:
#   Authorization: Bearer <token>
FINPLAN_API_TOKEN=

# Where wish-board images are stored (served at /wish-images/...).
# docker-compose mounts a named volume here so images survive redeploys.
FINPLAN_IMAGE_DIR=/srv/finplan/wish-images
